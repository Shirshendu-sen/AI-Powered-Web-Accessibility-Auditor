# Keep the build context tiny and secret-free.

# Dependencies (installed fresh inside the image)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env (never bake secrets into an image)
.env
.env.*
!.env.example

# VCS / editor / OS
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store

# Docker artifacts
Dockerfile
.dockerignore
docker-compose*.yml

# Tests / docs that aren't needed at runtime
tests
test
*.md
