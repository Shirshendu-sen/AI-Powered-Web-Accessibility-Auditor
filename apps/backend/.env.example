# Backend service env vars — mirrors root .env.example and Appendix A.
# Real secret values live in .env (gitignored). Non-secret defaults may
# appear here for convenience.

# Database
MONGODB_URI=
MONGODB_DB_NAME=accessibility_auditor

# AI provider (Phase 4+)
AI_PROVIDER=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
MAX_IMAGES_PER_SCAN=5

# Orchestration API (Phase 7+)
SCANNER_SERVICE_URL=http://127.0.0.1:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
