# Consolidated env var reference for the whole project — NAMES ONLY, NO VALUES.
# This file is documentation. Running services load their OWN .env files
# colocated with them (apps/backend/.env, services/scanner/.env, etc.).
# Every variable here mirrors Appendix A of docs/guide.md — keep both in sync.

# --- Database (backend) ---
MONGODB_URI=
MONGODB_DB_NAME=

# --- AI provider (backend) ---
AI_PROVIDER=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
MAX_IMAGES_PER_SCAN=

# --- Backend service ---
SCANNER_SERVICE_URL=
CORS_ALLOWED_ORIGINS=
BACKEND_PORT=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=
